# Fermi plugin .gitignore

# Python
__pycache__/
*.pyc

# Telegram media (downloaded files, not tracked)
media/outbox/
media/inbox/

# Secrets
**/config.json
.env

# OS
Thumbs.db
.DS_Store

# Large components and dependencies
fish_speech/
voice_cloning/
venv/
**/node_modules/
**/.next/
**/build/
**/*.exe

# Dynamic data, media, and state
**/*.jsonl
**/*.wav
**/*.ogg
media/relay_state.json
media/rgb_state.txt
memory/telegram/
memory/reflections/
memory/dreams/
